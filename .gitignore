# ----------------------------

# Java / Maven

# ----------------------------

# Compiled files

*.class

# Maven build directory

**/target/

# Maven wrapper (keep jar, ignore logs)

.mvn/wrapper/maven-wrapper.jar
.mvn/wrapper/maven-wrapper.properties
.mvn/wrapper/maven-wrapper.jar

# Package artifacts

*.jar
*.war
*.ear
*.nar

# Dependency archives

*.zip
*.tar.gz
*.rar

# Logs

*.log

# JVM crash logs

hs_err_pid*
replay_pid*

# ----------------------------

# IDE

# ----------------------------

# VS Code

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# IntelliJ (if someone opens project there)

.idea/
*.iml

# Eclipse

.project
.classpath
.settings/

# ----------------------------

# OS Files

# ----------------------------

.DS_Store
Thumbs.db
desktop.ini

# ----------------------------

# AI / MCP / Cursor

# ----------------------------

.cursor/
.github/
.mcp/
.cache/

